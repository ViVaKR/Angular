# 모든 텍스트 파일 자동 처리
* text=auto

# 소스 코드 파일들은 LF로 강제
*.ts text eol=lf
*.js text eol=lf
*.html text eol=lf
*.css text eol=lf
*.scss text eol=lf
*.json text eol=lf
*.md text eol=lf
*.svg text eol=lf
*.xml text eol=lf

# 쉘 스크립트
*.sh text eol=lf

# 바이너리 파일은 그대로
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.pdf binary
