# Logs
logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
lerna-debug.log*
.vscode/
**/.vscode/
# Diagnostic reports (https://nodejs.org/api/report.html)
report.[0-9]*.[0-9]*.[0-9]*.[0-9]*.json

# Runtime data
pids
*.pid
*.seed
*.pid.lock

# Directory for instrumented libs generated by jscoverage/JSCover
lib-cov

# Coverage directory used by tools like istanbul
coverage
*.lcov

# nyc test coverage
.nyc_output
.DS_Store

# Grunt intermediate storage (https://gruntjs.com/creating-plugins#storing-task-files)
.grunt

# Bower dependency directory (https://bower.io/)
bower_components

# node-waf configuration
.lock-wscript

# Compiled binary addons (https://nodejs.org/api/addons.html)
build/Release

# Dependency directories
node_modules/
jspm_packages/

# TypeScript v1 declaration files
typings/

# TypeScript cache
*.tsbuildinfo

# Optional npm cache directory
.npm

# Optional eslint cache
.eslintcache

# Microbundle cache
.rpt2_cache/
.rts2_cache_cjs/
.rts2_cache_es/
.rts2_cache_umd/

# Optional REPL history
.node_repl_history

# Output of 'npm pack'
*.tgz

# Yarn Integrity file
.yarn-integrity

# dotenv environment variables file
.env
.env.test

# parcel-bundler cache (https://parceljs.org/)
.cache

# Next.js build output
.next

# Nuxt.js build / generate output
.nuxt
dist

# Gatsby files
.cache/
# Comment in the public line in if your project uses Gatsby and *not* Next.js
# https://nextjs.org/blog/next-9-1#public-directory-support
# public

# vuepress build output
.vuepress/dist

# Serverless directories
.serverless/

# FuseBox cache
.fusebox/

# DynamoDB Local files
.dynamodb/

# TernJS port file
.tern-port
angular/
demo-intro/node_modules/
demo-intro/.angular/
.env
.env*
.env.Local


# ══════════════════════════════════════════════
# 상위 .gitignore (현재 위치) - 추가 필요한 항목들
# ══════════════════════════════════════════════

# ── 현재 잘 설정된 것들 ✅ ──────────────────────
# node_modules, dist, .env, .vscode 등 OK

# ── 🔥 Angular 전용 누락 항목 ──────────────────

# Angular 캐시 (현재 .angular/ 폴더가 커밋될 수 있어!)
BUDDHAM-CO-KR/.angular/
**/.angular/

# Angular environment 시크릿 (핵심!)
BUDDHAM-CO-KR/src/environments/environment.ts
BUDDHAM-CO-KR/src/environments/environment.development.ts
# 아래는 커밋 OK (템플릿용)
# !BUDDHAM-CO-KR/src/environments/environment.template.ts

# ── 🔥 macOS 누락 항목 ──────────────────────────
# .DS_Store 는 있는데 하위 폴더까지 적용 안될 수 있어
**/.DS_Store
BUDDHAM-CO-KR/.DS_Store  # 현재 6.1k 파일이 이미 존재!

# ── 🔥 Docker 관련 ───────────────────────────────
# docker 폴더 안에 시크릿 있을 수 있음
BUDDHAM-CO-KR/docker/*.env
BUDDHAM-CO-KR/docker-compose.override.yaml

# ── 🔥 기타 누락 ─────────────────────────────────
# Angular 빌드 출력 (dist 는 있는데 하위 경로 명시 권장)
BUDDHAM-CO-KR/dist/

# api.http 는 API 키나 토큰이 있을 수 있어 확인 필요!
# BUDDHAM-CO-KR/api.http  ← 내용 확인 후 결정
