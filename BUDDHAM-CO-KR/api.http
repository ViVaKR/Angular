### 1. SignIn
# @name SignIn

POST {{HOST}}/Account/SignIn
Content-Type: application/json

{
  "email": "{{email}}",
  "password": "{{password}}"
}


### 1-2. SignIn hellomybj
# @name SignInHelloMyBj

POST {{HOST}}/Account/SignIn
Content-Type: application/json

{
  "email": "{{hellomybjEmail}}",
  "password": "{{password}}"
}

### 2. Tokens
@token = {{SignIn.response.body.token}}
@refreshToken = {{SignIn.response.body.refreshToken}}

### 2-2. Tokens
@tokenHelloMyBj = {{SignInHelloMyBj.response.body.token}}
@refreshTokenHelloMyBj = {{SignInHelloMyBj.response.body.refreshToken}


### 3. ValidateToken
GET {{HOST}}/Account/test-claims
Authorization: Bearer {{token}}


### 4. UpdateProfile
PUT {{HOST}}/Account/{{id}}
Authorization: Bearer {{token}}
Content-Type: application/json

{
  "Id": "{{id}}",
  "fullName": "김범준",
  "pseudonym": "붓다핸섬",
  "avatar": "avatar-2.svg"
}


### 5. DeleteAccount

DELETE {{HOST}}/Account/cancel-account
Authorization: Bearer {{token}}
Content-Type: application/json

{
  "email": "{{email}}",
  "password": "{{password}}"
}

### 6. Refresh Token
# @name RefreshToken
POST {{HOST}}/Account/refresh-token
Content-Type: application/json

{
  "token": "{{token}}",
  "email": "{{email}}",
  "refreshToken": "{{refreshToken}}"
}

### 7. ListAccount
GET {{HOST}}/Account
Authorization: Bearer {{token}}
Accept: application/json

### 8. CountAccounts
GET {{HOST}}/Account/total
Accept: application/json

### 9. ListRoles
GET {{HOST}}/role/list
Authorization: Bearer {{token}}


