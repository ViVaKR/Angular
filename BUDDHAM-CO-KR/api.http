### 4. UpdateProfile
PUT {{HOST}}/Account/{{id}}
Authorization: Bearer {{token}}
Content-Type: application/json

{
  "Id": "{{id}}",
  "fullName": "김범준",
  "pseudonym": "붓다핸섬",
  "avatar": "avatar-2.svg"
}


### 5. DeleteAccount

DELETE {{HOST}}/Account/cancel-account
Authorization: Bearer {{token}}
Content-Type: application/json

{
  "email": "{{email}}",
  "password": "{{password}}"
}

### 6. Refresh Token
# @name RefreshToken
POST {{HOST}}/Account/refresh-token
Content-Type: application/json

{
  "token": "{{token}}",
  "email": "{{email}}",
  "refreshToken": "{{refreshToken}}"
}

